# Example .env file for Hybrid Data Security System
# Copy this file to .env and replace the values with your credentials.

EMAIL_USER=your_gmailid_@gmail.com
EMAIL_PASS=your-gmail-app-password

# Admin login credentials (optional; defaults are set in code)
ADMIN_EMAIL=your_admin_email@example.com
ADMIN_USERNAME=Set_Yours_in_Pages.js
ADMIN_PASSWORD=Set_Yours_in_Pages.js

# Optional Cloudinary configuration if you want remote image uploads
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
