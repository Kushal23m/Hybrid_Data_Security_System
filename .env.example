# Example .env file for Hybrid Data Security System
# Copy this file to .env and replace the values with your credentials.

EMAIL_USER=your_gmailid_@gmail.com
EMAIL_PASS=your-gmail-app-password

# Optional Cloudinary configuration if you want remote image uploads
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
